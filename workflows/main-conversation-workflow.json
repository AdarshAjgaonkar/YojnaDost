      ],
      "id": "f1055111-775c-4033-923a-992b31d47411",
      "name": "ParseAgentResponse"
    },
    {
      "parameters": {
        "jsCode": "// 1. Grab your placeholder system prompt (from Day 4-6 of your guide)[cite: 2]\nconst systemPrompt = `Your name is \"YojnaDost\", a friendly AI assistant that helps people in India discover government welfare schemes they qualify for. First introduce yourself. Let the user know what you do.\n\nCollect: age, annual income, occupation, state, caste category, gender, disability status, and ask if they'd like to be notified about new schemes in future. Ask ONE or TWO questions at a time. Warm, simple, respectful tone — no jargon.\n\nWhen you have all the details, respond ONLY with JSON using these EXACT field names, nothing else:\n{\"status\":\"ready_to_match\",\"profile\":{\"age\":number,\"income\":number,\"occupation\":\"string\",\"state\":\"string\",\"caste_category\":\"string\",\"gender\":\"string\",\"disability\":boolean,\"opt_in_notifications\":boolean}}\n\nIf any field wasn't explicitly provided by the user, use these defaults instead of omitting the field: caste_category defaults to \"Any\", gender defaults to \"Any\", disability defaults to false, opt_in_notifications defaults to false.\n\nOtherwise, while still collecting information, respond ONLY with JSON:\n{\"status\":\"collecting\",\"message\":\"your next question or acknowledgment here\"}\n\nNever output anything outside the JSON object. Never rename, abbreviate, or substitute the field names shown above — use exactly: age, income, occupation, state, caste_category, gender, disability, opt_in_notifications.`;\n\n// 2. Initialize the array with the system instruction\nconst messages = [\n  { role: \"system\", content: systemPrompt }\n];\n\n// 3. Retrieve all history rows pulled from the Google Sheets node\nconst isRestartCommand = $('CheckAlreadyMatched').first().json.isRestartCommand;\nconst historyRows = isRestartCommand ? [] : $('Filtering').all();\n\n\n// 4. Loop through the sheet rows and append them to the conversation array\n// Note: This assumes your Sheet columns are named 'sender' (user/assistant) and 'text'\nfor (const row of historyRows) {\n  if (row.json.role && row.json.message) {\n    messages.push({\n      role: row.json.role.trim(), \n      content: String(row.json.message)\n    });\n  }\n}\n\n// 5. Reach back and grab the current incoming user message from your first Code node\n// Replace 'Code' with the exact name of your first extraction node if you renamed it\nconst currentInput = $('Code in JavaScript').first().json; \n\n// 6. Append the fresh user message to the very end of the chain\nmessages.push({\n  role: \"user\",\n  content: String(currentInput.user_message)\n});\n\n// 7. Output the completed array so the HTTP Request node can map it via {{ $json.messages }}\nreturn [{ json: { messages: messages } }];"
      },
