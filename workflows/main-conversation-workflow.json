    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.choices[0].message.content;\n\nfunction extractJson(rawText) {\n  const match = rawText.match(/\\{[\\s\\S]*\\}/);\n  if (!match) return null;\n  try {\n    return JSON.parse(match[0]);\n  } catch (e) {\n    return null;\n  }\n}\n\nconst parsed = extractJson(raw);\n\nif (!parsed) {\n  return [{ \n    json: { \n      status: \"collecting\", \n      message: \"Sorry, could you repeat that?\", \n      chat_id: $('Code in JavaScript').first().json.chat_id \n    } \n  }];\n}\n\nreturn [{ json: { ...parsed, chat_id: $('Code in JavaScript').first().json.chat_id } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
